# Copy to .env and fill in as needed. Everything works with mock data/AI if left blank.

DATABASE_URL=postgresql+psycopg2://postgres:postgres@localhost:5432/forex_terminal
CORS_ORIGINS=["http://localhost:3000"]

# AI_PROVIDER: "mock" (default), "claude", or "openai"
AI_PROVIDER=mock
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

DEFAULT_ACCOUNT_BALANCE=100000
DEFAULT_DAILY_LOSS_LIMIT_PCT=5
DEFAULT_WEEKLY_LOSS_LIMIT_PCT=8
DEFAULT_MONTHLY_LOSS_LIMIT_PCT=10
